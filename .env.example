# At least one embedding provider is required
OPENAI_API_KEY=
GEMINI_API_KEY=

# Server settings
HOST=0.0.0.0
PORT=8420

# Registry — auto-register corpora for discovery by agents
# Default: https://registry.noosphere.ai
# Set to "none" to disable auto-registration
NOOSPHERE_REGISTRY=https://registry.noosphere.ai

# Stripe — required only for paid corpus access
# Self-hosted creators use their own Stripe keys and keep 100%
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
