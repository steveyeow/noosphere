# ── Required: at least one embedding provider ──
# Gemini is free-tier friendly; OpenAI is more widely used
# If both are set, Gemini is preferred (higher rate limits)
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Server ──
HOST=0.0.0.0
PORT=8420

# ── Optional: all below have sensible defaults ──

# App URL — auto-detected as http://localhost:8420 for local use
# Set explicitly when deploying to a public URL
# APP_URL=https://your-domain.com

# Database — leave empty for SQLite (default, zero setup)
# Set to PostgreSQL for cloud/multi-user deployment
# DATABASE_URL=postgres://user:pass@host:5432/noosphere

# Registry — your node auto-joins the Noosphere network on startup
# Set to "none" to run as a standalone node
# NOOSPHERE_REGISTRY=none

# Enrichment scheduler — auto-polls RSS feeds and re-indexes (minutes, 0=disabled)
# ENRICHMENT_INTERVAL_MINUTES=60

# Stripe — required only if you want to charge for corpus access
# Self-hosted creators use their own Stripe keys and keep 100%
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloud mode (noosphere.wiki only) ──
# Everything below is ignored unless ENABLE_CLOUD=true
# Self-hosted users do NOT need any of these
# ENABLE_CLOUD=true
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=your-jwt-secret
# STRIPE_PRO_PRICE_ID=price_...
