# At least one embedding provider is required
OPENAI_API_KEY=
GEMINI_API_KEY=

# Server settings
HOST=0.0.0.0
PORT=8420

# Database — leave empty for SQLite (default, self-hosted)
# Set to a PostgreSQL connection string for cloud/serverless deployment
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# App URL — auto-detected for localhost; set explicitly for production
# APP_URL=https://app.noosphere.wiki

# Registry — set to the Noosphere registry URL to join the discovery network
# Self-hosted nodes register metadata (name, tags, endpoint) with the registry
# Leave empty to run as a standalone node
# NOOSPHERE_REGISTRY=https://app.noosphere.wiki

# Stripe — required only for paid corpus access
# Self-hosted creators use their own Stripe keys and keep 100%
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloud mode (commercial hosting only) ──
# Everything below is ignored unless ENABLE_CLOUD=true
# Self-hosted users do NOT need any of these

# ENABLE_CLOUD=true
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=your-jwt-secret
# STRIPE_PRO_PRICE_ID=price_...
